[Unit]
Description=FreePBX First Boot Install
After=network-online.target
Wants=network-online.target
ConditionPathExists=/root/bootstrap.sh

[Service]
Type=oneshot
ExecStart=/bin/bash /root/bootstrap.sh
ExecStartPost=/bin/rm -f /root/bootstrap.sh
RemainAfterExit=yes
StandardOutput=journal+console
StandardError=journal+console

[Install]
WantedBy=multi-user.target
